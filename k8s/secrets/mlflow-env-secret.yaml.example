apiVersion: v1
kind: Secret
metadata:
  name: mlflow-env-secret
  namespace: mlflow
type: Opaque
stringData:
  BACKEND_STORE_URI: "postgresql://<MLFLOW_DB_USER>:<MLFLOW_DB_PASSWORD>@mlflow-postgres-postgresql:5432/mlflow"
  AWS_ACCESS_KEY_ID: "<MINIO_ROOT_USER>"
  AWS_SECRET_ACCESS_KEY: "<MINIO_ROOT_PASSWORD>"
